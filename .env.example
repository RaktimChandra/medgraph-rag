# MedGraph-RAG Environment Variables
# Copy to .env and fill in your values

# ── LLM API ──────────────────────────────────────────────────
# Gemini (recommended — free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional alternatives
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── TigerGraph ───────────────────────────────────────────────
# Option A: TigerGraph Savanna (tgcloud.io — recommended, free $60 credits)
TIGERGRAPH_HOST=https://your-instance.tgcloud.io
TIGERGRAPH_GRAPH=MedGraph
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=your_password_here
TIGERGRAPH_SECRET=your_secret_here

# Option B: Community Edition (local Docker)
# TIGERGRAPH_HOST=http://localhost:9000
# TIGERGRAPH_USERNAME=tigergraph
# TIGERGRAPH_PASSWORD=tigergraph

# ── GraphRAG Service ─────────────────────────────────────────
GRAPHRAG_SERVICE_URL=http://localhost:8000

# ── Evaluation ───────────────────────────────────────────────
# Hugging Face (free tier — https://huggingface.co/settings/tokens)
HF_TOKEN=your_hf_token_here

# ── Dataset ──────────────────────────────────────────────────
# PubMed Entrez email (required by NCBI)
ENTREZ_EMAIL=your_email@example.com

# ── Optional ─────────────────────────────────────────────────
TG_LICENSE_KEY=
